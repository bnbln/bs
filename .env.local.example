# Resend API Settings
RESEND_API_KEY=re_xxxxxxxxx
# `contacts.create` for newsletter signup requires a full access API key.

# Works without a custom domain in Resend test mode.
# If you verify a domain later, replace this with your domain sender.
RESEND_FROM="Portfolio Contact <onboarding@resend.dev>"

# Inbox for contact form messages
CONTACT_EMAIL=your@mail.com

# Optional: add newsletter signups to a segment in Resend.
# RESEND_NEWSLETTER_SEGMENT_ID=seg_xxxxxxxxx
